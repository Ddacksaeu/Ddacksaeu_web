# Publicly safe site identity used by local development and deployment.
NEXT_PUBLIC_APP_NAME=Graduate Contact Assistant

# At least 16 characters. Use a unique random value in production.
OWNER_SESSION_SECRET=replace-with-a-long-random-secret

# Owner-scoped profile/CV storage used by the hackathon build.
PROFILE_DATA_FILE=.data/profile-records.json

# Server-only origin for the existing FastAPI backend.  The Next.js rewrite
# exposes its versioned API locally at /backend-api/* (for example,
# /backend-api/health), so no backend URL or secret needs to reach browser code.
BACKEND_API_ORIGIN=http://127.0.0.1:8000
