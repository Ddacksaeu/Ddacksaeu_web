# Store real values only in an untracked .env file.
# Keep server-only secrets in backend runtime configuration.
OPENAI_API_KEY=
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=sqlite+pysqlite:///./ddacksaeu.db
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
RECOMMENDATION_SEMANTIC_PROVIDER=deterministic
RECOMMENDATION_EMBEDDING_MODEL=text-embedding-3-small
RECOMMENDATION_FRESHNESS_HALF_LIFE_DAYS=365
